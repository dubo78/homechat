{
  "name": "homechat",
  "version": "1.0.0",
  "description": "LAN P2P Walkie-Talkie",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --arm64"
  },
  "author": "dubo",
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.dubo.homechat",
    "productName": "HomeChat",
    "mac": {
      "category": "public.app-category.communication",
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ],
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "This app needs access to your microphone for walkie-talkie communication."
      }
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "directories": {
      "output": "dist"
    }
  }
}
